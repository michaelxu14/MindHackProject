#loading
    .loader-ring
    p Loading brain regions…
    #load-status.progress-text Initializing

#region-tooltip
    span.color-dot
    span.tooltip-text

#region-popup
    button.popup-close(type="button" aria-label="Close region info") ✕
    .popup-header
        span.color-dot
        .popup-title
    .popup-description

.brain-layout
    .brain-sidebar#sidebar
        .sidebar-header
            span.sidebar-label Controls
            
        .sidebar-body
            .sidebar-section
                .section-title Cross-Section
                .toggle-row
                    label Enable clip
                    label.toggle-switch
                        input#clip-toggle(type="checkbox")
                        span.toggle-slider
                .axis-btns#axis-btns
                    button.axis-btn.active(data-axis="x") Sagittal
                    button.axis-btn(data-axis="y") Coronal
                    button.axis-btn(data-axis="z") Axial

            .sidebar-section
                .section-title Regions
                #region-list.region-list
                    // Populated dynamically
                    
            .sidebar-section
                .section-title Activities
                .option-list
                    button.option-btn None
                    button.option-btn Doomscrolling
                    button.option-btn Cannabis 
                    button.option-btn Gambling
                    button.option-btn Solving a Puzzle
                    button.option-btn Exercise
                    button.option-btn Reading a Book
                    button.option-btn Finishing a Project

    button#sidebar-open-btn(title="Show regions panel") ☰

    .brain-main
        .brain-canvas-wrap
            #brain-canvas
            .overlay-bottom
                .controls-hint
                    span
                        span.key LMB
                        |  Rotate
                    span
                        span.key RMB
                        |  Pan
                    span
                        span.key Scroll
                        |  Zoom
                    span
                        span.key Click
                        |  Select region
                #stats.stats